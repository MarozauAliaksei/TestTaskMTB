# --- LLM backend (Ollama, OpenAI-compatible) ---
# Локально — Ollama, ключ не проверяется, значение произвольное.
# Для облачного деплоя без GPU — любой OpenAI-совместимый провайдер,
# например Groq: LLM_BASE_URL=https://api.groq.com/openai/v1,
# LLM_MODEL=<актуальное имя модели из консоли Groq>, LLM_API_KEY=<реальный ключ>.
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen2.5:3b-instruct
LLM_API_KEY=ollama

# --- Pipelines / OpenWebUI ---
PIPELINES_API_KEY=0p3n-w3bu!

# --- ASR ---
WHISPER_MODEL=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8

# --- FastAPI (added on Day 4) ---
API_PORT=8000
